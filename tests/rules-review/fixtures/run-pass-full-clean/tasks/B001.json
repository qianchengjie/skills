{
  "kind": "rules-review-task",
  "schemaVersion": 2,
  "runId": "run-pass-full-clean",
  "reviewBatchId": "B001",
  "ruleSetId": "RS001",
  "reviewItems": [
    {
      "reviewItemId": "RI001",
      "ruleRef": "CORE-001",
      "targetKind": "changed_unit",
      "targetId": "T001",
      "required": true
    },
    {
      "reviewItemId": "RI002",
      "ruleRef": "TYPE-001",
      "targetKind": "candidate",
      "targetId": "T002",
      "required": true
    },
    {
      "reviewItemId": "RI003",
      "ruleRef": "UI-001",
      "targetKind": "candidate",
      "targetId": "T002",
      "required": false
    }
  ],
  "rules": [
    {
      "namespace": "CORE",
      "ruleRef": "CORE-001",
      "sourceFile": ".agents/rules/core.md",
      "sourceHash": "sha256-core",
      "trigger": [
        "always"
      ],
      "appliesTo": [
        "*"
      ],
      "summary": "核心规则",
      "ruleLevel": "MUST"
    },
    {
      "namespace": "TYPE",
      "ruleRef": "TYPE-001",
      "sourceFile": ".agents/rules/type.md",
      "sourceHash": "sha256-type",
      "trigger": [
        "type"
      ],
      "appliesTo": [
        "src/**/*.ts"
      ],
      "summary": "类型规则",
      "ruleLevel": "SHOULD"
    },
    {
      "namespace": "UI",
      "ruleRef": "UI-001",
      "sourceFile": ".agents/rules/ui.md",
      "sourceHash": "sha256-ui",
      "trigger": [
        "ui"
      ],
      "appliesTo": [
        "src/**/*.tsx"
      ],
      "summary": "界面规则",
      "ruleLevel": "ADVISORY"
    }
  ],
  "targets": [
    {
      "targetId": "T001",
      "targetKind": "changed_unit",
      "loc": "src/example.ts:10",
      "summary": "修改请求参数"
    },
    {
      "targetId": "T002",
      "targetKind": "candidate",
      "loc": "src/example.ts:12",
      "summary": "相关响应字段"
    }
  ],
  "outputContract": {
    "format": "strict_json",
    "schemaRef": "schemas/shard.schema.json"
  },
  "applicabilityMatrix": [
    {
      "ruleRef": "CORE-001",
      "targetId": "T001",
      "targetKind": "changed_unit",
      "applicability": "applicable",
      "reviewItemId": "RI001",
      "evidence": [
        {
          "summary": "CORE-001 applies to T001",
          "loc": "src/example.ts:10"
        }
      ]
    },
    {
      "ruleRef": "TYPE-001",
      "targetId": "T002",
      "targetKind": "candidate",
      "applicability": "applicable",
      "reviewItemId": "RI002",
      "evidence": [
        {
          "summary": "TYPE-001 applies to T002",
          "loc": "src/example.ts:12"
        }
      ]
    }
  ]
}
