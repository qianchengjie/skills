{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents.local/rules-review/shard.schema.json",
  "title": "rules-review reviewBatch shard",
  "type": "object",
  "required": ["kind", "schemaVersion", "runId", "reviewBatchId", "results"],
  "properties": {
    "kind": { "const": "rules-review-shard" },
    "schemaVersion": { "const": 2 },
    "runId": { "type": "string", "minLength": 1 },
    "reviewBatchId": { "type": "string", "minLength": 1 },
    "results": { "type": "array", "items": { "$ref": "#/$defs/result" } }
  },
  "$defs": {
    "result": {
      "type": "object",
      "required": ["reviewItemId", "status"],
      "properties": {
        "reviewItemId": { "type": "string", "pattern": "^RI\\d{3}$" },
        "status": { "enum": ["passed", "finding", "observation", "not_applicable", "cannot_verify"] },
        "findingId": { "type": "string", "pattern": "^F\\d{3}$" },
        "origin": { "enum": ["introduced_by_change", "worsened_by_change", "exposed_by_change", "pre_existing"] },
        "priority": { "enum": ["must_fix", "should_fix"] },
        "priorityReason": { "type": "string", "minLength": 1 },
        "upgradeReason": { "type": "string", "minLength": 1 },
        "originReason": { "type": "string", "minLength": 1 },
        "acceptedRisk": { "$ref": "#/$defs/acceptedRisk" },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "failureChecks": { "type": "array", "items": { "$ref": "#/$defs/failureCheck" } },
        "reason": { "type": "string" }
      }
    },
    "failureCheck": {
      "type": "object",
      "required": ["condition", "outcome", "evidence"],
      "properties": {
        "conditionId": { "type": "string", "minLength": 1 },
        "condition": { "type": "string", "minLength": 1 },
        "outcome": { "enum": ["checked_no_violation", "not_triggered"] },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      }
    },
    "acceptedRisk": {
      "type": "object",
      "required": ["status", "acceptedBy", "scope", "reason"],
      "properties": {
        "status": { "const": "accepted" },
        "acceptedBy": { "enum": ["human", "user", "project_owner"] },
        "scope": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "expiresAt": { "type": "string", "minLength": 1 },
        "followUp": { "type": "string", "minLength": 1 }
      },
      "anyOf": [
        { "required": ["expiresAt"] },
        { "required": ["followUp"] }
      ]
    },
    "evidence": {
      "type": "object",
      "required": ["summary"],
      "anyOf": [
        { "required": ["loc"] },
        { "required": ["source"] }
      ],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "loc": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 }
      }
    }
  }
}
