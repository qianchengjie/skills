{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents.local/rules-review/dispatch.schema.json",
  "title": "rules-review dispatch",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "runId", "ruleSet", "targets", "applicabilityMatrix", "reviewItems", "executionPlan", "reviewBatches", "changedFiles", "inputSnapshot"],
  "properties": {
    "kind": { "const": "rules-review-dispatch" },
    "schemaVersion": { "const": 3 },
    "runId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$" },
    "fullReason": { "type": "string", "minLength": 1 },
    "continuation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseRunId"],
      "properties": {
        "baseRunId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$" }
      }
    },
    "ruleSet": {
      "type": "object",
      "required": ["ruleSetId", "sourceIndexHash", "candidateRuleRefs", "selectedRuleRefs", "requiredRuleRefs", "excludedRuleRefs", "globallyNotApplicableRuleRefs", "ruleSources"],
      "properties": {
        "ruleSetId": { "type": "string", "minLength": 1 },
        "sourceIndexHash": { "type": "string", "minLength": 1 },
        "candidateRuleRefs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "selectedRuleRefs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "requiredRuleRefs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "excludedRuleRefs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "globallyNotApplicableRuleRefs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "ruleSources": { "type": "array", "items": { "$ref": "#/$defs/ruleSource" } }
      }
    },
    "targets": {
      "type": "object",
      "required": ["changedUnits", "candidates", "contextExpansions"],
      "properties": {
        "changedUnits": { "type": "array", "items": { "$ref": "#/$defs/target" } },
        "candidates": { "type": "array", "items": { "$ref": "#/$defs/target" } },
        "contextExpansions": { "type": "array", "items": { "$ref": "#/$defs/contextExpansion" } }
      }
    },
    "applicabilityMatrix": { "type": "array", "items": { "$ref": "#/$defs/applicabilityEntry" } },
    "reviewItems": { "type": "array", "items": { "$ref": "#/$defs/reviewItem" } },
    "executionPlan": { "$ref": "#/$defs/executionPlan" },
    "reviewBatches": { "type": "array", "items": { "$ref": "#/$defs/reviewBatch" } },
    "changedFiles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "inputSnapshot": {
      "type": "object",
      "required": ["files"],
      "properties": {
        "files": { "type": "array", "items": { "$ref": "#/$defs/inputSnapshotFile" } }
      }
    },
    "priorReviewCheck": false
  },
  "oneOf": [
    {
      "required": ["fullReason"],
      "not": { "required": ["continuation"] }
    },
    {
      "required": ["continuation"],
      "not": { "required": ["fullReason"] },
      "properties": { "reviewItems": { "minItems": 1 } }
    }
  ],
  "allOf": [
    {
      "if": {
        "required": ["executionPlan"],
        "properties": {
          "executionPlan": {
            "required": ["mode"],
            "properties": { "mode": { "const": "no_batch" } }
          }
        }
      },
      "then": {
        "properties": {
          "reviewBatches": { "maxItems": 0 },
          "executionPlan": {
            "properties": {
              "selectedBy": { "const": "ai" },
              "humanOverride": { "type": "null" }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["executionPlan"],
        "properties": {
          "executionPlan": {
            "required": ["mode"],
            "properties": { "mode": { "const": "single_batch" } }
          }
        }
      },
      "then": { "properties": { "reviewBatches": { "minItems": 1, "maxItems": 1 } } }
    },
    {
      "if": {
        "required": ["executionPlan"],
        "properties": {
          "executionPlan": {
            "required": ["mode"],
            "properties": { "mode": { "const": "multi_batch" } }
          }
        }
      },
      "then": { "properties": { "reviewBatches": { "minItems": 2 } } }
    }
  ],
  "$defs": {
    "executionPlan": {
      "type": "object",
      "required": ["mode", "selectedBy", "policyVersion", "metrics", "signals", "reason", "humanOverride"],
      "properties": {
        "mode": { "enum": ["no_batch", "single_batch", "multi_batch"] },
        "selectedBy": { "enum": ["ai", "human_override"] },
        "policyVersion": { "const": "review-execution-policy/v1" },
        "metrics": { "$ref": "#/$defs/executionMetrics" },
        "signals": { "$ref": "#/$defs/executionSignals" },
        "reason": { "type": "string", "minLength": 1 },
        "humanOverride": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/humanOverride" }
          ]
        }
      }
    },
    "executionMetrics": {
      "type": "object",
      "required": ["changedUnits", "candidates", "targets", "requiredRuleRefs", "reviewItems"],
      "properties": {
        "changedUnits": { "type": "integer", "minimum": 0 },
        "candidates": { "type": "integer", "minimum": 0 },
        "targets": { "type": "integer", "minimum": 0 },
        "requiredRuleRefs": { "type": "integer", "minimum": 0 },
        "reviewItems": { "type": "integer", "minimum": 0 }
      }
    },
    "executionSignals": {
      "type": "object",
      "required": ["userRequestedConcurrency"],
      "properties": {
        "userRequestedConcurrency": { "type": "boolean" }
      }
    },
    "humanOverride": {
      "type": "object",
      "required": ["requestedMode", "risk"],
      "properties": {
        "requestedMode": { "enum": ["single_batch", "multi_batch"] },
        "risk": { "type": "string", "minLength": 1 }
      }
    },
    "ruleSource": {
      "type": "object",
      "required": ["namespace", "ruleRef", "ruleLevel", "sourceFile", "sourceHash", "trigger", "appliesTo"],
      "anyOf": [
        { "required": ["summary"] },
        { "required": ["ruleText"] }
      ],
      "properties": {
        "namespace": { "type": "string", "minLength": 1 },
        "ruleRef": { "type": "string", "minLength": 1 },
        "ruleLevel": { "enum": ["MUST", "SHOULD", "ADVISORY"] },
        "sourceFile": { "type": "string", "minLength": 1 },
        "sourceHash": { "type": "string", "minLength": 1 },
        "trigger": {},
        "appliesTo": {},
        "summary": { "type": "string", "minLength": 1 },
        "ruleText": { "type": "string", "minLength": 1 },
        "failureConditions": { "type": "array", "items": { "$ref": "#/$defs/failureCondition" } },
        "requiredContext": { "type": "array", "items": { "$ref": "#/$defs/requiredContext" } }
      }
    },
    "failureCondition": {
      "type": "object",
      "required": ["conditionId", "summary"],
      "properties": {
        "conditionId": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "requiredContext": {
      "type": "object",
      "required": ["contextId", "summary"],
      "properties": {
        "contextId": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "contextExpansion": {
      "type": "object",
      "required": ["reason", "addedTargetIds"],
      "properties": {
        "expansionId": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "addedTargetIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "requiredContextRefs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    },
    "target": {
      "type": "object",
      "required": ["targetId", "targetKind"],
      "properties": {
        "targetId": { "type": "string", "pattern": "^T\\d{3,}$" },
        "targetKind": { "type": "string", "minLength": 1 },
        "inputRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "loc": { "type": "string" },
        "source": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "applicabilityEntry": {
      "type": "object",
      "required": ["ruleRef", "targetId", "targetKind", "applicability", "evidence"],
      "properties": {
        "ruleRef": { "type": "string", "minLength": 1 },
        "targetId": { "type": "string", "pattern": "^T\\d{3,}$" },
        "targetKind": { "type": "string", "minLength": 1 },
        "applicability": { "enum": ["applicable", "not_applicable"] },
        "reviewItemId": { "type": "string", "pattern": "^RI\\d{3,}$" },
        "reason": { "type": "string", "minLength": 1 },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      }
    },
    "reviewItem": {
      "type": "object",
      "required": ["reviewItemId", "ruleRef", "targetKind", "targetId", "required"],
      "properties": {
        "reviewItemId": { "type": "string", "pattern": "^RI\\d{3,}$" },
        "ruleRef": { "type": "string", "minLength": 1 },
        "targetKind": { "type": "string", "minLength": 1 },
        "targetId": { "type": "string", "pattern": "^T\\d{3,}$" },
        "required": { "type": "boolean" }
      }
    },
    "reviewBatch": {
      "type": "object",
      "required": ["reviewBatchId", "ruleSetId", "reviewItemIds", "taskRef", "shardRef", "returnStatus", "aggregateStatus"],
      "properties": {
        "reviewBatchId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$" },
        "ruleSetId": { "type": "string", "minLength": 1 },
        "reviewItemIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "taskRef": { "type": "string", "pattern": "^tasks/[A-Za-z0-9][A-Za-z0-9_-]*\\.json$" },
        "shardRef": { "type": ["string", "null"], "pattern": "^shards/[A-Za-z0-9][A-Za-z0-9_-]*\\.json$" },
        "returnStatus": { "enum": ["not_started", "started", "returned", "not_returned", "format_invalid", "untrusted"] },
        "aggregateStatus": { "enum": ["aggregated", "not_aggregated"] },
        "unaggregatedReason": { "type": ["string", "null"] }
      }
    },
    "inputSnapshotFile": {
      "type": "object",
      "required": ["inputRef", "state"],
      "properties": {
        "inputRef": { "type": "string", "minLength": 1 },
        "state": { "enum": ["present", "deleted"] },
        "contentHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      },
      "allOf": [
        {
          "if": { "properties": { "state": { "const": "present" } } },
          "then": { "required": ["contentHash"] }
        },
        {
          "if": { "properties": { "state": { "const": "deleted" } } },
          "then": { "not": { "required": ["contentHash"] } }
        }
      ]
    },
    "evidence": {
      "type": "object",
      "required": ["summary"],
      "anyOf": [
        { "required": ["loc"] },
        { "required": ["source"] }
      ],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "loc": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 }
      }
    }
  }
}
