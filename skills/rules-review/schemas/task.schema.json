{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents.local/rules-review/task.schema.json",
  "title": "rules-review reviewBatch task",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "runId", "reviewBatchId", "ruleSetId", "reviewRange", "inputSnapshot", "reviewItems", "rules", "targets", "applicabilityMatrix", "outputContract"],
  "properties": {
    "kind": { "const": "rules-review-task" },
    "schemaVersion": { "const": 4 },
    "runId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$" },
    "reviewBatchId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$" },
    "ruleSetId": { "type": "string", "minLength": 1 },
    "reviewRange": { "$ref": "dispatch.schema.json#/properties/reviewRange" },
    "inputSnapshot": { "$ref": "dispatch.schema.json#/properties/inputSnapshot" },
    "reviewItems": { "type": "array", "items": { "$ref": "dispatch.schema.json#/$defs/reviewItem" } },
    "rules": { "type": "array", "items": { "$ref": "dispatch.schema.json#/$defs/ruleSource" } },
    "targets": {
      "type": "array",
      "items": {
        "$ref": "dispatch.schema.json#/$defs/target",
        "properties": { "contentHash": false }
      }
    },
    "applicabilityMatrix": { "type": "array", "items": { "$ref": "dispatch.schema.json#/$defs/applicabilityEntry" } },
    "outputContract": {
      "type": "object",
      "required": ["format", "schemaRef"],
      "properties": {
        "format": { "const": "strict_json" },
        "schemaRef": { "const": "schemas/shard.schema.json" }
      }
    }
  }
}
